{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "linden",
  "name": "Endfield API",
  "description": "终末地协议终端 API 文档 — 游戏数据查询、蓝图库、Wiki 百科、抽卡统计等开放接口平台。",
  "colors": {
    "primary": "#d4a017",
    "light": "#FFD000",
    "dark": "#b8860b"
  },
  "favicon": "/logo/favicon.svg",
  "logo": {
    "light": "/logo/logo-light.svg",
    "dark": "/logo/logo-dark.svg",
    "href": "https://end.shallow.ink"
  },
  "fonts": {
    "heading": {
      "family": "Space Grotesk",
      "weight": 700
    },
    "body": {
      "family": "DM Sans"
    }
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "background": {
    "color": {
      "dark": "#050505",
      "light": "#f9f9f9"
    },
    "decoration": "grid"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "vitesse-dark"
      }
    }
  },
  "icons": {
    "library": "lucide"
  },
  "navbar": {
    "links": [
      {
        "label": "协议终端",
        "href": "https://end.shallow.ink"
      },
      {
        "type": "github",
        "href": "https://github.com/Dnyo666/endfield-docs"
      }
    ],
    "primary": {
      "type": "button",
      "label": "控制台",
      "href": "https://end.shallow.ink/dashboard"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Dnyo666/endfield-docs",
      "website": "https://end.shallow.ink"
    },
    "links": [
      {
        "header": "平台",
        "items": [
          { "label": "协议终端", "href": "https://end.shallow.ink" },
          { "label": "控制台", "href": "https://end.shallow.ink/dashboard" },
          { "label": "开发者", "href": "https://end.shallow.ink/dashboard/developer" }
        ]
      },
      {
        "header": "文档",
        "items": [
          { "label": "快速开始", "href": "/quickstart" },
          { "label": "认证指南", "href": "/authentication" },
          { "label": "API 参考", "href": "/api-reference" }
        ]
      }
    ]
  },
  "api": {
    "openapi": "openapi.json",
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "params": {
      "expanded": "all"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "文档",
        "groups": [
          {
            "group": "开始使用",
            "icon": "terminal",
            "pages": [
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "核心概念",
            "icon": "cpu",
            "pages": [
              "concepts/credentials",
              "concepts/rate-limiting",
              "concepts/error-codes",
              "concepts/subscription"
            ]
          },
          {
            "group": "使用指南",
            "icon": "wrench",
            "pages": [
              "guides/web-integration",
              "guides/bot-integration",
              "guides/gacha-analysis",
              "guides/blueprint-library"
            ]
          }
        ]
      },
      {
        "tab": "API 参考",
        "icon": "file-json",
        "openapi": "openapi.json"
      },
      {
        "tab": "更新日志",
        "icon": "clock",
        "pages": [
          "changelog"
        ]
      }
    ]
  }
}
